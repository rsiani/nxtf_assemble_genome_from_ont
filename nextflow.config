nextflow {
    // Prevent Nextflow from trying to download processes it can't run
    process {
        // Set the default executor to local (or 'slurm' / 'pbs' if you have a cluster later)
        executor = 'local'
        
        // Memory and CPU defaults
        memory = '10 GB'
        cpus = 4


        // Error handling
        errorStrategy = 'finish'
        maxRetries = 1
        
        // Enable process caching to speed up repeated runs
        cache.maxSize = '10 GB'
        cache.maxDiffSize = '1 GB'
    }

    // Define the work directory (relative to project root)
    // Nextflow will create this automatically, but we define the base here
    workDir = './work'
    
    // Define the base directory for temporary files
    // Ensures temp files don't clutter the project root
    tmpDir = './work/tmp'
}

// --- Micromamba Environment Configuration ---
// This section tells Nextflow how to handle your conda/micromamba environments
// We assume you created an environment named 'nextflow-env' with the necessary tools
// or you will define the environments per process.

process {
    // Use conda for environment management
    conda = true
    
    // Optional: If you want Nextflow to use a specific base environment path
    condaBasePath = '~/micromamba' 
}

// --- Tool Definitions (Optional but Recommended) ---
// You can define specific paths or channels here if you don't rely solely on conda-forge
// This is useful if you need to pin specific versions of tools like Flye or Minimap2

